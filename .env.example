# ============================================================
# Voyaz — environment variables
# Copy this file to .env.local and fill in your own values.
# Never commit real keys to the repository.
# ============================================================

# --- REQUIRED: Supabase (auth + database) ---
# Free tier: https://supabase.com → create a project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# --- OPTIONAL: Google Maps (interactive maps in the trip planner) ---
# https://console.cloud.google.com → enable "Maps JavaScript API"
# Without it the app runs, but map views will not load.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- OPTIONAL: Google Places (place search & city validation) ---
# https://console.cloud.google.com → enable "Places API (New)"
# Can be the same key as above if both APIs are enabled on it.
GOOGLE_PLACES_API_KEY=

# --- OPTIONAL: Google Gemini (AI trip generation) ---
# Free tier: https://aistudio.google.com → Get API key
# Without it, trip generation returns a friendly "demo mode" message.
GOOGLE_GENERATIVE_AI_API_KEY=

# --- OPTIONAL: Ably (realtime group chat & notifications) ---
# Free tier: https://ably.com → create an app → API keys
# Without it, realtime features are silently disabled.
ABLY_API_KEY=

# --- OPTIONAL: Unsplash (destination cover images) ---
# Free tier: https://unsplash.com/developers
# Without it, image search returns empty results.
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=
